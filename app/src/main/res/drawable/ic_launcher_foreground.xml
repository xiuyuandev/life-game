<?xml version="1.0" encoding="utf-8"?>
<!--
    Premium LifeUp launcher icon.
    A 5-point star inside a double ring on a teal/cyan radial gradient.
    Designed to read clearly at 48dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background radial gradient circle -->
    <path
        android:pathData="M0,0h108v108h-108z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76"
                android:startColor="#006B5E"
                android:endColor="#003D34" />
        </aapt:attr>
    </path>

    <!-- Outer ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#5EDFC0"
        android:strokeWidth="1.5"
        android:pathData="M54,18 C75,18 90,33 90,54 C90,75 75,90 54,90 C33,90 18,75 18,54 C18,33 33,18 54,18 Z M54,22 C72,22 86,36 86,54 C86,72 72,86 54,86 C36,86 22,72 22,54 C22,36 36,22 54,22 Z" />

    <!-- Inner ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF8A50"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.7"
        android:pathData="M54,28 C70,28 80,40 80,54 C80,68 70,80 54,80 C38,80 28,68 28,54 C28,40 38,28 54,28 Z" />

    <!-- Star -->
    <path
        android:fillColor="#5EDFC0"
        android:pathData="M54,38 L58,50 L70,50 L60,58 L64,70 L54,62 L44,70 L48,58 L38,50 L50,50 Z" />

    <!-- Star highlight -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.6"
        android:pathData="M50,42 L52,46 L48,46 Z" />
</vector>
